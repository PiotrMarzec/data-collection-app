# ─────────────────────────────────────────────────────────────────
# This file documents the secrets required by the application.
#
# IN PRODUCTION — do NOT create a .env file on the VM manually.
# All values below are stored as GitHub Secrets in the "production"
# Environment and are written to the VM's .env by the deploy workflow
# on every push to master.
#
# To add/update a secret:
#   GitHub → repo → Settings → Environments → production → Add secret
#
# FOR LOCAL DEVELOPMENT — copy this file to .env and fill in values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# Docker image — set automatically by the deploy workflow in production.
# For local dev, use any name; the image will be built from the Dockerfile
# automatically on first `docker compose up`.
IMAGE=data-collection-app:local

# Port binding host (optional).
# Default is 127.0.0.1 (localhost only — for production behind Caddy).
# Set to 0.0.0.0 for local dev to expose the app on all network interfaces.
APP_HOST=0.0.0.0

# ── Database ─────────────────────────────────────────────────────
DB_USER=app_user
DB_PASSWORD=CHANGE_ME

# ── Application secrets ──────────────────────────────────────────

# HMAC-SHA256 key used to sign registration links.
# Generate with: openssl rand -hex 32
APP_SIGNATURE_SECRET=CHANGE_ME

# Plain-text password for the /admin panel.
APP_ADMIN_PASSWORD=CHANGE_ME

# Bearer token for the external REST API (/api/external).
# Generate with: openssl rand -hex 32
APP_API_TOKEN=CHANGE_ME

# ── Optional: welcome page copy ──────────────────────────────────
# Defaults are used when these are not set.
# APP_WELCOME_TITLE=Welcome!
# APP_WELCOME_DESCRIPTION=You have been invited to complete your registration. Please provide your email address to continue.
